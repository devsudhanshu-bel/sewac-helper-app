generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}





/*
|--------------------------------------------------------------------------
| ENUMS
|--------------------------------------------------------------------------
*/

enum WasteType {
  DRY
  WET
}





/*
|--------------------------------------------------------------------------
| RFID MAPPING
|--------------------------------------------------------------------------
| One Citizen -> Multiple RFIDs
|--------------------------------------------------------------------------
*/

model RFIDMapping {

  id Int @id @default(autoincrement())


  /*
  |--------------------------------------------------------------------------
  | CITIZEN DATA
  |--------------------------------------------------------------------------
  */

  slno String

  phoneNumber String?


  /*
  |--------------------------------------------------------------------------
  | RFID DATA
  |--------------------------------------------------------------------------
  */

  rfid String @unique

  wasteType WasteType?


  /*
  |--------------------------------------------------------------------------
  | META
  |--------------------------------------------------------------------------
  */

  createdAt DateTime @default(now())


  /*
  |--------------------------------------------------------------------------
  | CONSTRAINTS
  |--------------------------------------------------------------------------
  */

  @@unique([slno, wasteType])
}





/*
|--------------------------------------------------------------------------
| MODERATOR
|--------------------------------------------------------------------------
*/

model Moderator {

  id Int @id @default(autoincrement())

  username String @unique

  password String

  role String @default("MODERATOR")

  createdAt DateTime @default(now())
}





/*
|--------------------------------------------------------------------------
| TRACKING LOG
|--------------------------------------------------------------------------
| Verification Snapshot Log
|--------------------------------------------------------------------------
*/

model TrackingLog {

  id Int @id @default(autoincrement())


  /*
  |--------------------------------------------------------------------------
  | WORKER
  |--------------------------------------------------------------------------
  */

  workerId String


  /*
  |--------------------------------------------------------------------------
  | CITIZEN
  |--------------------------------------------------------------------------
  */

  slno String?

  citizenName String?

  phoneNumber String?


  /*
  |--------------------------------------------------------------------------
  | RFID SNAPSHOT
  |--------------------------------------------------------------------------
  */

  drySlno String?

  wetSlno String?


  /*
  |--------------------------------------------------------------------------
  | STATUS
  |--------------------------------------------------------------------------
  */

  status String @default("FOUND")

  remarks String?


  /*
  |--------------------------------------------------------------------------
  | META
  |--------------------------------------------------------------------------
  */

  createdAt DateTime @default(now())
}





/*
|--------------------------------------------------------------------------
| REMARK
|--------------------------------------------------------------------------
*/

model Remark {

  id Int @id @default(autoincrement())

  remark String

  createdAt DateTime @default(now())
}





/*
|--------------------------------------------------------------------------
| SURVEY
|--------------------------------------------------------------------------
*/

model Survey {

  city String?

  ward String?

  area String?

  wasteGeneratorTypes String?

  houseNumber String?

  floorNumber String?

  householdType String?

  personName String?

  contactNumber String?

  numberOfPeople String?

  buildingPhoto String?

  id Int @id @default(autoincrement())

  @@map("survey_attribute_specific")
}





/*
|--------------------------------------------------------------------------
| MASTER CITIZEN DATA
|--------------------------------------------------------------------------
*/

model MasterCitizenData {

  id Int @id @default(autoincrement())


  /*
  |--------------------------------------------------------------------------
  | PRIMARY LINK
  |--------------------------------------------------------------------------
  */

  phoneNumber String @unique


  /*
  |--------------------------------------------------------------------------
  | RFID DATA
  |--------------------------------------------------------------------------
  */

  dryRFID String?

  wetRFID String?

  drySlno String?

  wetSlno String?


  /*
  |--------------------------------------------------------------------------
  | SURVEY DATA
  |--------------------------------------------------------------------------
  */

  city String?

  ward String?

  area String?

  wasteGeneratorTypes String?

  houseNumber String?

  floorNumber String?

  householdType String?

  personName String?

  contactNumber String?

  numberOfPeople String?

  buildingPhoto String?


  /*
  |--------------------------------------------------------------------------
  | META
  |--------------------------------------------------------------------------
  */

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt


  @@map("master_citizen_data")
}